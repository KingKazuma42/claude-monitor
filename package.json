{
  "name": "claude-monitor",
  "displayName": "Claude Monitor",
  "description": "Monitor and control multiple Claude Code CLI instances from VSCode",
  "version": "0.2.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KingKazuma42/claude-monitor.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeMonitor",
          "title": "Claude Monitor",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "claudeMonitor": [
        {
          "type": "webview",
          "id": "claudeMonitor.panel",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeMonitor.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Claude Monitor"
      },
      {
        "command": "claudeMonitor.newSession",
        "title": "New Claude Session",
        "icon": "$(add)",
        "category": "Claude Monitor"
      },
      {
        "command": "claudeMonitor.focusPanel",
        "title": "Show Claude Monitor Panel",
        "category": "Claude Monitor"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeMonitor.refresh",
          "when": "view == claudeMonitor.panel",
          "group": "navigation"
        },
        {
          "command": "claudeMonitor.newSession",
          "when": "view == claudeMonitor.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Claude Monitor",
      "properties": {
        "claudeMonitor.pollIntervalMs": {
          "type": "number",
          "default": 5000,
          "description": "Process polling interval in milliseconds"
        },
        "claudeMonitor.contextWindowTokens": {
          "type": "number",
          "default": 200000,
          "minimum": 1,
          "description": "Token limit used to calculate context window usage percentage"
        },
        "claudeMonitor.notifications.permission": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code warning when a session enters permission-waiting state"
        },
        "claudeMonitor.notifications.contextWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code warning when a session crosses the context warning threshold"
        },
        "claudeMonitor.notifications.contextWarningThresholdPct": {
          "type": "number",
          "default": 90,
          "minimum": 1,
          "maximum": 100,
          "description": "Context usage percentage that triggers a VS Code warning"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package",
    "pretest": "npm run compile",
    "test": "node out/test/claudeCliArgs.test.js && node out/test/contextPct.test.js && node out/test/disambiguateNames.test.js && node out/test/sessionRouting.test.js && node out/test/runtimeSessionMetadata.test.js && node out/test/sessionName.test.js && node out/test/permissionInput.test.js && node out/test/compact.test.js",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "typescript": "^5.0.0"
  }
}
